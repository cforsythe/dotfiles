      "Bash(mkdir:*)",
      "Bash(awk:*)",
      "Bash(ps:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(rg:*)",
      "Bash(ls:*)",
      "Bash(cp:*)"
